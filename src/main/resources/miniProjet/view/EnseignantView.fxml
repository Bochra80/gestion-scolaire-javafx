<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="miniProjet.controller.EnseignantController"
            prefWidth="900" prefHeight="600">

    <!-- BARRE HAUTE -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color:#2ecc71;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>

            <Button text="⬅"
                    onAction="#handleRetourMenu"
                    style="-fx-background-color:#2c3e50; -fx-text-fill:white;"/>

            <Label text="GESTION DES ENSEIGNANTS"
                   style="-fx-text-fill:white;">
                <font>
                    <Font size="20"/>
                </font>
            </Label>
        </HBox>
    </top>

    <!-- CONTENU -->
    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- FORMULAIRE -->
            <TitledPane text="Informations de l'enseignant" collapsible="false">
                <GridPane hgap="10" vgap="10">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- LIGNE 0 : ID + Spécialité -->
    <Label text="ID :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="txtId"
               GridPane.rowIndex="0"
               GridPane.columnIndex="1"
               promptText="ID (optionnel)"/>

    <Label text="Spécialité :" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
    <TextField fx:id="txtSpecialite"
               GridPane.rowIndex="0"
               GridPane.columnIndex="3"/>

    <!-- LIGNE 1 : Nom + Prénom -->
    <Label text="Nom :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="txtNom"
               GridPane.rowIndex="1"
               GridPane.columnIndex="1"/>

    <Label text="Prénom :" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
    <TextField fx:id="txtPrenom"
               GridPane.rowIndex="1"
               GridPane.columnIndex="3"/>

    <!-- LIGNE 2 : Email + Téléphone -->
    <Label text="Email :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="txtEmail"
               GridPane.rowIndex="2"
               GridPane.columnIndex="1"/>

    <Label text="Téléphone :" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
    <TextField fx:id="txtTelephone"
               GridPane.rowIndex="2"
               GridPane.columnIndex="3"/>
</GridPane>

            </TitledPane>

            <!-- BOUTONS -->
            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#handleAjouter"
                        style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>
                <Button text="Modifier" onAction="#handleModifier"
                        style="-fx-background-color:#f39c12; -fx-text-fill:white;"/>
                <Button text="Supprimer" onAction="#handleSupprimer"
                        style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>
                <Button text="Actualiser" onAction="#handleActualiser"
                        style="-fx-background-color:#3498db; -fx-text-fill:white;"/>
                <Button text="Vider" onAction="#handleVider"
                        style="-fx-background-color:#95a5a6; -fx-text-fill:white;"/>
            </HBox>

            <!-- RECHERCHE -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Rechercher:"/>
                <TextField fx:id="txtRecherche" prefWidth="300"/>
                <Button text="Rechercher" onAction="#handleRechercher"
                        style="-fx-background-color:#9b59b6; -fx-text-fill:white;"/>
            </HBox>

            <!-- TABLE -->
            <TableView fx:id="tableEnseignants" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                    <TableColumn fx:id="colSpecialite" text="Spécialité" prefWidth="150"/>
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>
