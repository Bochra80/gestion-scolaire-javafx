<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="miniProjet.controller.EmploiTempsController"
            prefWidth="1000" prefHeight="650">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color:#1e3a8a;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>

            <Button text="⬅" onAction="#handleRetourMenu"
                    style="-fx-background-color:#34495e; -fx-text-fill:white;"/>

            <Label text="GESTION DES EMPLOIS DU TEMPS" style="-fx-text-fill:white;">
                <font><Font size="20"/></font>
            </Label>
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <TitledPane text="Informations de l'emploi du temps" collapsible="false">
                <GridPane hgap="10" vgap="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                    <Label text="Groupe :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbGroupe" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Matière :" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="cbMatiere" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Enseignant :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbEnseignant" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Jour :" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="cbJour" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                    <Label text="Heure début :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtHeureDebut" promptText="HH:mm"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Heure fin :" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtHeureFin" promptText="HH:mm"
                               GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                    <Label text="Salle :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtSalle" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
            </TitledPane>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#handleAjouter"
                        style="-fx-background-color:#22c55e; -fx-text-fill:white;" prefWidth="120"/>
                <Button text="Supprimer" onAction="#handleSupprimer"
                        style="-fx-background-color:#ef4444; -fx-text-fill:white;" prefWidth="120"/>
                <Button text="Actualiser" onAction="#handleActualiser"
                        style="-fx-background-color:#3b82f6; -fx-text-fill:white;" prefWidth="120"/>
                <Button text="Vider" onAction="#handleVider"
                        style="-fx-background-color:#9ca3af; -fx-text-fill:white;" prefWidth="120"/>
            </HBox>

            <TableView fx:id="tableEmplois" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colGroupe" text="Groupe" prefWidth="120"/>
                    <TableColumn fx:id="colMatiere" text="Matière" prefWidth="150"/>
                    <TableColumn fx:id="colEnseignant" text="Enseignant" prefWidth="150"/>
                    <TableColumn fx:id="colJour" text="Jour" prefWidth="100"/>
                    <TableColumn fx:id="colDebut" text="Début" prefWidth="100"/>
                    <TableColumn fx:id="colFin" text="Fin" prefWidth="100"/>
                    <TableColumn fx:id="colSalle" text="Salle" prefWidth="100"/>
                </columns>
            </TableView>

        </VBox>
    </center>
</BorderPane>
