<!-- MatiereView.fxml -->
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.MatiereController" prefWidth="900" prefHeight="600">
    <top>
        <VBox style="-fx-background-color: #9b59b6; -fx-padding: 15;">
            <Label text="GESTION DES MATIÈRES" style="-fx-text-fill: white;">
                <font><Font name="System Bold" size="20"/></font>
            </Label>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            
            <TitledPane text="Informations de la matière" collapsible="false">
                <GridPane hgap="10" vgap="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
                    <Label text="Code:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtCode" GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="200"/>
                    <Label text="Coefficient:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCoefficient" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Volume horaire:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtVolumeHoraire" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                </GridPane>
            </TitledPane>
            
            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#handleAjouter" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" prefWidth="100"/>
                <Button text="Modifier" onAction="#handleModifier" style="-fx-background-color: #f39c12; -fx-text-fill: white;" prefWidth="100"/>
                <Button text="Supprimer" onAction="#handleSupprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" prefWidth="100"/>
                <Button text="Actualiser" onAction="#handleActualiser" style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="100"/>
                <Button text="Vider" onAction="#handleVider" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="100"/>
            </HBox>
            
            <TableView fx:id="tableMatieres" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="250"/>
                    <TableColumn fx:id="colCode" text="Code" prefWidth="150"/>
                    <TableColumn fx:id="colCoefficient" text="Coefficient" prefWidth="120"/>
                    <TableColumn fx:id="colVolumeHoraire" text="Volume horaire" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>